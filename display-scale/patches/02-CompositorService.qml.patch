   Loader {
     id: backendLoader
     onLoaded: {
       if (item) {
         if (isScroll) {
           item.msgCommand = "scrollmsg";
         }
         root.backend = item;
         setupBackendConnections();
         backend.initialize();
+        applySavedScales();
